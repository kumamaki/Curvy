# Claude Code agent-isolation scratch space.
.claude/worktrees/

# Generated by xcodegen — project.yml is the source of truth.
mac/Curvy.xcodeproj/
mac/Curvy/Resources/Info.plist
# Entitlements files are committed source, NOT auto-generated, because
# xcodegen's `entitlements:` block forcibly overwrites per-config
# CODE_SIGN_ENTITLEMENTS — which defeats the Debug-only sandbox-off
# override that InjectionNext hot reload needs.

# sourcekit-lsp ↔ Xcode bridge config — per-machine, points at local
# DerivedData paths. Regenerate with `xcode-build-server config
# -project mac/Curvy.xcodeproj -scheme Curvy`.
buildServer.json

# Build output
mac/build/
mac/dist/
DerivedData/
/build/
/dist/
